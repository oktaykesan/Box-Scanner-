# BoxScan Mobile — Environment Configuration
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real credentials.
#
# Variable mapping to backend:
#   EXPO_PUBLIC_API_BASE_URL  ->  backend APP_BASE_URL  (must be reachable from the device)
#   EXPO_PUBLIC_API_KEY       ->  backend API_SHARED_SECRET  (must match exactly)

# Backend API base URL — use the LAN IP of the machine running the backend,
# NOT localhost (mobile devices cannot reach localhost on your host machine).
# Example: http://192.168.1.100:3000
EXPO_PUBLIC_API_BASE_URL=CHANGE_ME_e.g._http://192.168.1.x:3000

# Shared API secret — must match API_SHARED_SECRET in the backend .env exactly.
# Generate: openssl rand -hex 32
EXPO_PUBLIC_API_KEY=CHANGE_ME_USE_SAME_VALUE_AS_BACKEND_API_SHARED_SECRET
