# BoxScan Backend — Environment Configuration

PORT=3000
APP_BASE_URL=http://localhost:3000

# Storage
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# AI Provider: mock | gemini | local
AI_PROVIDER=mock
# IMPORTANT: Revoke any key that was ever committed to git and generate a new one
GEMINI_API_KEY=CHANGE_ME
AI_GATEWAY_URL=

# Upload limits
MAX_UPLOAD_MB=10

# Auth — REQUIRED, server refuses to start without this
# Generate: openssl rand -hex 32
API_SHARED_SECRET=CHANGE_ME_USE_STRONG_SECRET

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
